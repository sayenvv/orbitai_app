{
  "name": "orbit-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "dev:control": "turbo run dev --filter=control_center_app",
    "dev:admin": "turbo run dev --filter=admin-app",
    "dev:chat": "turbo run dev --filter=chat-app",
    "build:control": "turbo run build --filter=control_center_app",
    "build:admin": "turbo run build --filter=admin-app",
    "build:chat": "turbo run build --filter=chat-app",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20"
  }
}
